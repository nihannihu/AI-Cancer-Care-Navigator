# Example environment variables for Onco-Navigator AI
# Copy this file to .env and fill in your actual values

# Geoapify API key for hospital location services
GEOAPIFY_API_KEY=your_geoapify_api_key_here

# MongoDB connection string (optional - app works without it)
MONGODB_URI=your_mongodb_connection_string_here

# Application host and port
APP_HOST=0.0.0.0
APP_PORT=8000

# Path to the breast cancer CNN model (optional)
MODEL_PATH=ml/breast_cancer_cnn.h5